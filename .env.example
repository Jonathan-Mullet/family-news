NODE_ENV=production
BASE_URL=https://news.jonathan-mullet.com
SESSION_SECRET=change_me_to_random_64_chars
PORT=3000

DB_HOST=mysql
DB_USER=familynews
DB_PASSWORD=change_me
DB_NAME=family_news

# Used only on first startup to create the admin account
ADMIN_NAME=Jonathan
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=change_me

# Optional: email for password resets and new-post notifications
# iCloud:  EMAIL_HOST=smtp.mail.me.com  EMAIL_PORT=587  (use an App-Specific Password)
# Gmail:   EMAIL_HOST=smtp.gmail.com    EMAIL_PORT=587  (use an App Password)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Family News <your@email.com>
