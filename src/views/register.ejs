<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="fn-page">
  <div class="fn-page-inner">
    <div class="fn-page-header">
      <h1 class="fn-page-title">Join Family News</h1>
      <p class="fn-page-sub">Create your account to get started.</p>
    </div>

    <div class="fn-card">
      <% if (flash.error) { %>
        <div class="fn-flash-error"><%= flash.error %></div>
      <% } %>

      <form method="POST" action="/register">
        <input type="hidden" name="invite" value="<%= invite %>">

        <div class="fn-field">
          <label class="fn-label" for="reg-name">Your name</label>
          <input class="fn-input" type="text" id="reg-name" name="name" required autocomplete="name" placeholder="e.g. Grandma Sue">
        </div>

        <div class="fn-field">
          <label class="fn-label" for="reg-email">Email</label>
          <input class="fn-input" type="email" id="reg-email" name="email" required autocomplete="email">
        </div>

        <div class="fn-field">
          <%
            const _bdMonths = ['January','February','March','April','May','June','July','August','September','October','November','December'];
            const _bdNow = new Date().getFullYear();
          %>
          <label class="fn-label">Birthday</label>
          <div style="display:flex;gap:0.5rem;">
            <select name="birthday_month" class="fn-select" style="flex:1.5;width:auto;min-width:0;" required>
              <option value="" disabled selected>Month</option>
              <% _bdMonths.forEach(function(m, i) { const v = ('0'+(i+1)).slice(-2); %>
              <option value="<%= v %>"><%= m %></option>
              <% }); %>
            </select>
            <select name="birthday_day" class="fn-select" style="flex:0.8;width:auto;min-width:0;" required>
              <option value="" disabled selected>Day</option>
              <% for (let _d = 1; _d <= 31; _d++) { const v = ('0'+_d).slice(-2); %>
              <option value="<%= v %>"><%= _d %></option>
              <% } %>
            </select>
            <select name="birthday_year" class="fn-select" style="flex:1;width:auto;min-width:0;" required>
              <option value="" disabled selected>Year</option>
              <% for (let _y = _bdNow; _y >= 1920; _y--) { %>
              <option value="<%= _y %>"><%= _y %></option>
              <% } %>
            </select>
          </div>
        </div>

        <div class="fn-field">
          <label class="fn-label" for="reg-password">Password <span style="font-weight:400;letter-spacing:0;text-transform:none;opacity:0.7;">(min 8 characters)</span></label>
          <input class="fn-input" type="password" id="reg-password" name="password" required minlength="8" autocomplete="new-password">
        </div>

        <button type="submit" class="fn-submit">Create Account</button>
      </form>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
</body></html>
