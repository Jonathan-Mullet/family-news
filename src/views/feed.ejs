<%- include('partials/head', { title: 'Feed' }) %>
<%- include('partials/nav') %>

<div class="max-w-2xl mx-auto px-4 py-6 space-y-4">

  <% if (flash.error) { %><div class="p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl text-red-700 dark:text-red-300 text-sm"><%= flash.error %></div><% } %>

  <%# Post creation card %>
  <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 p-4">
    <form method="POST" action="/posts" id="post-form" enctype="multipart/form-data">
      <%# Hidden real file input — populated by photo editor %>
      <input type="file" name="photo" id="photo-input" accept="image/*" class="hidden">
      <div class="space-y-3">
        <textarea name="content" rows="3" placeholder="Share some news with the family..."
          class="w-full border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 rounded-xl px-3 py-2.5 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent"
          id="post-content" maxlength="2000"></textarea>
        <div id="post-extras" class="hidden space-y-2.5">
          <input type="text" name="title" placeholder="Add a title (optional)"
            class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600">
          <%# Photo row %>
          <div class="flex items-center gap-3 flex-wrap">
            <button type="button" id="photo-select-btn"
              class="flex items-center gap-1.5 text-xs px-3 py-2 border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors min-h-[36px]">
              📷 Add Photo
            </button>
            <div id="photo-preview-wrap" class="hidden flex items-center gap-2">
              <img id="photo-thumb" class="w-14 h-14 object-cover rounded-lg border border-slate-200 dark:border-slate-700" src="" alt="">
              <div class="flex flex-col gap-1">
                <button type="button" id="photo-edit-again" class="text-xs text-brand-600 dark:text-brand-400 hover:underline text-left">✏️ Edit</button>
                <button type="button" id="photo-remove" class="text-xs text-red-400 hover:underline text-left">✕ Remove</button>
              </div>
            </div>
          </div>
          <%# Schedule row %>
          <div>
            <label class="block text-xs text-slate-500 dark:text-slate-400 mb-1">Schedule (optional)</label>
            <input type="datetime-local" name="publish_at"
              class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600">
          </div>
        </div>
        <div class="flex items-center justify-between gap-2">
          <div class="flex items-center gap-2 min-w-0">
            <button type="button" id="extras-toggle" class="text-xs text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors whitespace-nowrap">
              + More
            </button>
            <span id="char-counter" class="text-xs text-slate-400 dark:text-slate-500 hidden">0 / 2000</span>
          </div>
          <button type="submit"
            class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors min-h-[40px] shrink-0">
            Post
          </button>
        </div>
      </div>
    </form>
  </div>

  <%# Feed %>
  <% if (!posts.length) { %>
  <div class="text-center py-16 text-slate-400 dark:text-slate-500">
    <div class="text-4xl mb-3">🌱</div>
    <p>No posts yet — be the first to share something!</p>
  </div>
  <% } %>

  <div id="feed" data-latest="<%= posts[0]?.id || 0 %>">
  <% posts.forEach(post => {
    const isScheduled = post.publish_at && new Date(post.publish_at) > new Date();
  %>
  <article class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden" data-post-id="<%= post.id %>">
    <% if (post.pinned) { %>
    <div class="px-4 pt-2 pb-0 flex items-center gap-1 text-xs text-brand-600 dark:text-brand-400 font-medium">
      <span>📌</span><span>Pinned</span>
    </div>
    <% } %>
    <div class="p-4">
      <%# Header %>
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <div class="w-9 h-9 rounded-full bg-brand-100 dark:bg-brand-600/20 flex items-center justify-center text-brand-600 dark:text-brand-400 font-semibold text-sm flex-shrink-0">
            <%= post.author_name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-800 dark:text-slate-100"><%= post.author_name %></p>
            <p class="text-xs text-slate-400 dark:text-slate-500 flex items-center gap-1.5">
              <% if (isScheduled && (user.id === post.user_id || user.role === 'admin')) { %>
              <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-amber-50 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 rounded font-medium">🕐 Scheduled</span>
              <% } else { %>
              <%= new Date(post.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'numeric', minute:'2-digit' }) %>
              <% if (post.edited_at) { %><span class="italic"> · edited</span><% } %>
              <% } %>
            </p>
          </div>
        </div>
        <% if (user.id === post.user_id || user.role === 'admin') { %>
        <div class="flex items-center gap-1">
          <% if (user.role === 'admin') { %>
          <form method="POST" action="/posts/<%= post.id %>/pin">
            <button type="submit" class="p-1.5 text-slate-300 dark:text-slate-600 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" title="<%= post.pinned ? 'Unpin post' : 'Pin post' %>">
              <span class="text-sm"><%= post.pinned ? '📌' : '📍' %></span>
            </button>
          </form>
          <% } %>
          <button class="edit-toggle p-1.5 text-slate-300 dark:text-slate-600 hover:text-brand-600 dark:hover:text-brand-400 transition-colors text-xs" data-post-id="<%= post.id %>" title="Edit post">✏️</button>
          <form method="POST" action="/posts/<%= post.id %>/delete" onsubmit="return confirm('Delete this post?')">
            <button type="submit" class="p-1.5 text-slate-300 dark:text-slate-600 hover:text-red-400 transition-colors text-sm">✕</button>
          </form>
        </div>
        <% } %>
      </div>

      <%# Content display %>
      <div class="post-content-display">
        <% if (post.title) { %><h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1"><%= post.title %></h2><% } %>
        <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed whitespace-pre-wrap"><%= post.content %></p>
      </div>

      <%# Inline edit form (hidden by default) %>
      <form method="POST" action="/posts/<%= post.id %>/edit" class="post-edit-form hidden space-y-2">
        <input type="text" name="title" placeholder="Title (optional)" value="<%= post.title || '' %>"
          class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600">
        <textarea name="content" rows="4" required maxlength="2000"
          class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 rounded-xl px-3 py-2 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-brand-600"><%= post.content %></textarea>
        <div class="flex gap-2 justify-end">
          <button type="button" class="edit-cancel text-xs text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 px-3 py-1.5 border border-slate-200 dark:border-slate-600 rounded-lg transition-colors" data-post-id="<%= post.id %>">Cancel</button>
          <button type="submit" class="text-xs bg-brand-600 hover:bg-brand-700 text-white px-3 py-1.5 rounded-lg transition-colors font-medium">Save</button>
        </div>
      </form>

      <%# Photo %>
      <% if (post.photo_url) { %>
      <div class="mt-3 rounded-xl overflow-hidden border border-slate-100 dark:border-slate-700">
        <img src="<%= post.photo_url %>" alt="" class="w-full object-cover max-h-80" loading="lazy" onerror="this.parentElement.remove()">
      </div>
      <% } %>

      <%# Link preview (only when no photo) %>
      <% if (post.preview_url && !post.photo_url) { %>
      <a href="<%= post.preview_url %>" target="_blank" rel="noopener" class="mt-3 flex gap-3 border border-slate-200 dark:border-slate-600 rounded-xl p-3 hover:border-brand-400 dark:hover:border-brand-500 transition-colors overflow-hidden">
        <% if (post.og_image) { %><img src="<%= post.og_image %>" class="w-16 h-16 object-cover rounded-lg flex-shrink-0" loading="lazy" onerror="this.remove()"><% } %>
        <div class="min-w-0">
          <p class="text-sm font-medium text-slate-700 dark:text-slate-200 truncate"><%= post.og_title || post.preview_url %></p>
          <% if (post.og_description) { %><p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 mt-0.5"><%= post.og_description %></p><% } %>
        </div>
      </a>
      <% } %>
    </div>

    <%# Reactions %>
    <div class="px-4 py-2 border-t border-slate-100 dark:border-slate-700 flex items-center gap-1 flex-wrap">
      <% ['❤️','👍','😂','😮','😢'].forEach(emoji => {
        const r = reactionsByPost[post.id]?.[emoji];
        const count = r?.count || 0;
        const active = r?.userReacted;
      %>
      <button class="reaction-btn flex items-center gap-1 px-2.5 py-1.5 rounded-full text-sm transition-all min-h-[36px]
        <%= active ? 'bg-brand-50 dark:bg-brand-600/20 border border-brand-200 dark:border-brand-700' : 'hover:bg-slate-50 dark:hover:bg-slate-700 border border-transparent' %>"
        data-post-id="<%= post.id %>" data-emoji="<%= emoji %>">
        <span><%= emoji %></span>
        <span class="reaction-count text-xs text-slate-500 dark:text-slate-400 <%= count === 0 ? 'hidden' : '' %>"><%= count %></span>
      </button>
      <% }) %>

      <%# Extended emoji picker %>
      <div class="relative ml-1">
        <button class="emoji-picker-toggle p-1.5 rounded-full text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 text-sm min-h-[36px] min-w-[36px]" data-post-id="<%= post.id %>">＋</button>
        <div class="emoji-picker hidden absolute bottom-10 left-0 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 rounded-2xl shadow-xl p-2 z-20 grid grid-cols-4 gap-1 w-40">
          <% ['🎉','🙏','🔥','💯','🫶','👏','🥳','😍','🤣','😭','💪','🎂','🌟','👀','🤔','💔'].forEach(e => { %>
          <button class="reaction-btn text-lg p-1.5 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors min-h-[40px]" data-post-id="<%= post.id %>" data-emoji="<%= e %>"><%= e %></button>
          <% }) %>
        </div>
      </div>

      <a href="/post/<%= post.id %>" class="ml-auto text-xs text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors px-2 py-1.5 min-h-[36px] flex items-center gap-1.5">
        <% if (post.read_count > 0) { %><span class="text-slate-300 dark:text-slate-600">👁 <%= post.read_count %></span><span class="text-slate-300 dark:text-slate-600">·</span><% } %>
        <%= post.comment_count %> comment<%= post.comment_count !== 1 ? 's' : '' %> →
      </a>
    </div>
  </article>
  <% }) %>
  </div>

</div>

<div id="refresh-toast" class="hidden fixed top-16 left-1/2 -translate-x-1/2 z-50 px-5 py-2.5 bg-brand-600 text-white text-sm rounded-full shadow-xl cursor-pointer font-medium">
  New posts — tap to refresh
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">

<%# Photo editor modal %>
<div id="photo-editor-modal" class="hidden fixed inset-0 bg-black z-[60] flex flex-col" style="padding-bottom:env(safe-area-inset-bottom)">
  <div class="flex items-center justify-between px-4 py-3 bg-slate-900 shrink-0 gap-3">
    <span class="text-white font-semibold text-sm">Edit Photo</span>
    <div class="flex gap-2">
      <button id="rotate-left" type="button" class="p-2 rounded-lg bg-slate-700 text-white text-xl leading-none hover:bg-slate-600 transition-colors">↺</button>
      <button id="rotate-right" type="button" class="p-2 rounded-lg bg-slate-700 text-white text-xl leading-none hover:bg-slate-600 transition-colors">↻</button>
    </div>
  </div>
  <div class="flex-1 min-h-0 overflow-hidden">
    <img id="crop-img" src="" alt="" class="block max-w-full">
  </div>
  <div class="flex gap-3 px-4 py-4 bg-slate-900 shrink-0">
    <button type="button" id="photo-cancel" class="flex-1 py-3 border border-slate-600 text-slate-200 rounded-xl text-sm font-medium hover:bg-slate-700 transition-colors">Cancel</button>
    <button type="button" id="photo-confirm" class="flex-1 py-3 bg-brand-600 text-white rounded-xl text-sm font-semibold hover:bg-brand-700 transition-colors">Use Photo</button>
  </div>
</div>

<script src="/js/app.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
<script>
  // Extras toggle
  const extrasToggle = document.getElementById('extras-toggle');
  const postExtras = document.getElementById('post-extras');
  extrasToggle.addEventListener('click', () => {
    const hidden = postExtras.classList.toggle('hidden');
    extrasToggle.textContent = hidden ? '+ More' : '− Less';
  });

  // Char counter
  const postContent = document.getElementById('post-content');
  const charCounter = document.getElementById('char-counter');
  postContent.addEventListener('input', () => {
    const len = postContent.value.length;
    charCounter.textContent = `${len} / 2000`;
    charCounter.classList.toggle('hidden', len === 0);
    charCounter.classList.toggle('text-red-500', len > 1900);
    charCounter.classList.toggle('text-slate-400', len <= 1900);
    charCounter.classList.toggle('dark:text-slate-500', len <= 1900);
  });

  // Edit-in-place toggle
  document.querySelectorAll('.edit-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const article = document.querySelector(`article[data-post-id="${btn.dataset.postId}"]`);
      article.querySelector('.post-content-display').classList.add('hidden');
      article.querySelector('.post-edit-form').classList.remove('hidden');
    });
  });
  document.querySelectorAll('.edit-cancel').forEach(btn => {
    btn.addEventListener('click', () => {
      const article = document.querySelector(`article[data-post-id="${btn.dataset.postId}"]`);
      article.querySelector('.post-content-display').classList.remove('hidden');
      article.querySelector('.post-edit-form').classList.add('hidden');
    });
  });

  // ── Photo editor ──────────────────────────────────────────────────────────
  const photoInput    = document.getElementById('photo-input');
  const photoSelectBtn = document.getElementById('photo-select-btn');
  const photoEditAgain = document.getElementById('photo-edit-again');
  const photoRemove   = document.getElementById('photo-remove');
  const photoPreviewWrap = document.getElementById('photo-preview-wrap');
  const photoThumb    = document.getElementById('photo-thumb');
  const modal         = document.getElementById('photo-editor-modal');
  const cropImg       = document.getElementById('crop-img');
  let cropper = null;
  let pendingDataUrl = null;  // holds original image for "edit again"

  function openEditor(dataUrl) {
    pendingDataUrl = dataUrl;
    cropImg.src = dataUrl;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    if (cropper) { cropper.destroy(); cropper = null; }
    // Wait for img to paint before initialising Cropper
    setTimeout(() => {
      cropper = new Cropper(cropImg, {
        viewMode: 1,
        autoCropArea: 0.95,
        movable: true,
        zoomable: true,
        scalable: false,
        background: false,
        guides: true,
      });
    }, 80);
  }

  function closeEditor() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    if (cropper) { cropper.destroy(); cropper = null; }
  }

  // Trigger hidden file input
  photoSelectBtn.addEventListener('click', () => photoInput.click());
  photoEditAgain.addEventListener('click', () => { if (pendingDataUrl) openEditor(pendingDataUrl); });

  // File selected → open editor
  photoInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => openEditor(ev.target.result);
    reader.readAsDataURL(file);
    photoInput.value = ''; // reset so same file can be re-selected
  });

  // Rotate controls
  document.getElementById('rotate-left').addEventListener('click', () => cropper?.rotate(-90));
  document.getElementById('rotate-right').addEventListener('click', () => cropper?.rotate(90));

  // Cancel
  document.getElementById('photo-cancel').addEventListener('click', closeEditor);

  // Confirm crop → produce a File and attach to input
  document.getElementById('photo-confirm').addEventListener('click', () => {
    if (!cropper) return;
    const canvas = cropper.getCroppedCanvas({ maxWidth: 1600, maxHeight: 1600, imageSmoothingQuality: 'high' });
    canvas.toBlob(blob => {
      // Attach blob as File to the real input
      const file = new File([blob], 'photo.jpg', { type: 'image/jpeg' });
      const dt = new DataTransfer();
      dt.items.add(file);
      photoInput.files = dt.files;

      // Show thumbnail + ensure extras visible
      const thumbUrl = canvas.toDataURL('image/jpeg', 0.85);
      photoThumb.src = thumbUrl;
      photoPreviewWrap.classList.remove('hidden');
      photoPreviewWrap.classList.add('flex');
      postExtras.classList.remove('hidden');
      extrasToggle.textContent = '− Less';

      closeEditor();
    }, 'image/jpeg', 0.92);
  });

  // Remove photo
  photoRemove.addEventListener('click', () => {
    const dt = new DataTransfer();
    photoInput.files = dt.files;
    pendingDataUrl = null;
    photoThumb.src = '';
    photoPreviewWrap.classList.add('hidden');
    photoPreviewWrap.classList.remove('flex');
  });
</script>
</body></html>
