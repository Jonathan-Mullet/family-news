<%- include('partials/head', { title: post.title || 'Post' }) %>
<%- include('partials/nav') %>

<div class="max-w-2xl mx-auto px-4 py-6 space-y-4">
  <a href="/" class="text-sm text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">← Back to feed</a>

  <%# Post %>
  <article class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden" data-post-id="<%= post.id %>">
    <% if (post.pinned) { %>
    <div class="px-5 pt-3 pb-0 flex items-center gap-1 text-xs text-brand-600 dark:text-brand-400 font-medium">
      <span>📌</span><span>Pinned post</span>
    </div>
    <% } %>
    <div class="p-5">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 rounded-full bg-brand-100 dark:bg-brand-600/20 flex items-center justify-center text-brand-600 dark:text-brand-400 font-semibold flex-shrink-0">
            <%= post.author_name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="font-semibold text-slate-800 dark:text-slate-100"><%= post.author_name %></p>
            <p class="text-xs text-slate-400 dark:text-slate-500 flex items-center gap-1.5">
              <%= new Date(post.created_at).toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric', year:'numeric', hour:'numeric', minute:'2-digit' }) %>
              <% if (post.edited_at) { %><span class="italic"> · edited</span><% } %>
              <% if (post.readCount > 0) { %>
              <span class="text-slate-300 dark:text-slate-600">·</span>
              <span class="flex items-center gap-0.5 text-slate-400 dark:text-slate-500">👁 Seen by <%= post.readCount %></span>
              <% } %>
            </p>
          </div>
        </div>
        <% if (user.id === post.user_id || user.role === 'admin') { %>
        <div class="flex items-center gap-1">
          <% if (user.role === 'admin') { %>
          <form method="POST" action="/posts/<%= post.id %>/pin">
            <button type="submit" class="p-1.5 text-slate-300 dark:text-slate-600 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" title="<%= post.pinned ? 'Unpin' : 'Pin' %>">
              <span><%= post.pinned ? '📌' : '📍' %></span>
            </button>
          </form>
          <% } %>
          <button class="edit-toggle p-1.5 text-slate-300 dark:text-slate-600 hover:text-brand-600 dark:hover:text-brand-400 transition-colors text-xs" data-post-id="<%= post.id %>" title="Edit post">✏️</button>
          <form method="POST" action="/posts/<%= post.id %>/delete" onsubmit="return confirm('Delete this post?')">
            <button type="submit" class="p-1.5 text-slate-300 dark:text-slate-600 hover:text-red-400 transition-colors">✕</button>
          </form>
        </div>
        <% } %>
      </div>

      <div class="post-content-display">
        <% if (post.title) { %><h1 class="text-xl font-bold text-slate-800 dark:text-slate-100 mb-2"><%= post.title %></h1><% } %>
        <p class="text-slate-700 dark:text-slate-300 leading-relaxed whitespace-pre-wrap"><%= post.content %></p>
      </div>

      <form method="POST" action="/posts/<%= post.id %>/edit" class="post-edit-form hidden space-y-2 mt-1">
        <input type="text" name="title" placeholder="Title (optional)" value="<%= post.title || '' %>"
          class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600">
        <textarea name="content" rows="5" required maxlength="2000"
          class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 rounded-xl px-3 py-2 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-brand-600"><%= post.content %></textarea>
        <div class="flex gap-2 justify-end">
          <button type="button" class="edit-cancel text-xs text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 px-3 py-1.5 border border-slate-200 dark:border-slate-600 rounded-lg transition-colors" data-post-id="<%= post.id %>">Cancel</button>
          <button type="submit" class="text-xs bg-brand-600 hover:bg-brand-700 text-white px-3 py-1.5 rounded-lg transition-colors font-medium">Save</button>
        </div>
      </form>

      <% if (post.photo_url) { %>
      <div class="mt-4 rounded-xl overflow-hidden border border-slate-100 dark:border-slate-700">
        <img src="<%= post.photo_url %>" alt="" class="w-full object-cover" loading="lazy" onerror="this.parentElement.remove()">
      </div>
      <% } %>

      <%# Link preview (only when no photo) %>
      <% if (post.preview_url && !post.photo_url) { %>
      <a href="<%= post.preview_url %>" target="_blank" rel="noopener" class="mt-3 flex gap-3 border border-slate-200 dark:border-slate-600 rounded-xl p-3 hover:border-brand-400 dark:hover:border-brand-500 transition-colors overflow-hidden">
        <% if (post.og_image) { %><img src="<%= post.og_image %>" class="w-16 h-16 object-cover rounded-lg flex-shrink-0" loading="lazy" onerror="this.remove()"><% } %>
        <div class="min-w-0">
          <p class="text-sm font-medium text-slate-700 dark:text-slate-200 truncate"><%= post.og_title || post.preview_url %></p>
          <% if (post.og_description) { %><p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 mt-0.5"><%= post.og_description %></p><% } %>
        </div>
      </a>
      <% } %>
    </div>

    <%# Reactions %>
    <div class="px-5 py-3 border-t border-slate-100 dark:border-slate-700 flex items-center gap-1.5 flex-wrap">
      <% ['❤️','👍','😂','😮','😢'].forEach(emoji => {
        const r = reactions[emoji];
        const count = r?.count || 0;
        const active = r?.userReacted;
      %>
      <button class="reaction-btn flex items-center gap-1 px-3 py-2 rounded-full text-sm transition-all min-h-[40px]
        <%= active ? 'bg-brand-50 dark:bg-brand-600/20 border border-brand-200 dark:border-brand-700' : 'hover:bg-slate-50 dark:hover:bg-slate-700 border border-transparent' %>"
        data-post-id="<%= post.id %>" data-emoji="<%= emoji %>">
        <span><%= emoji %></span>
        <span class="reaction-count text-xs text-slate-500 dark:text-slate-400 <%= count === 0 ? 'hidden' : '' %>"><%= count %></span>
      </button>
      <% }) %>

      <%# Extended emoji picker %>
      <div class="relative ml-1">
        <button class="emoji-picker-toggle p-1.5 rounded-full text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 text-sm min-h-[40px] min-w-[40px]" data-post-id="<%= post.id %>">＋</button>
        <div class="emoji-picker hidden absolute bottom-12 left-0 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 rounded-2xl shadow-xl p-2 z-20 grid grid-cols-4 gap-1 w-40">
          <% ['🎉','🙏','🔥','💯','🫶','👏','🥳','😍','🤣','😭','💪','🎂','🌟','👀','🤔','💔'].forEach(e => { %>
          <button class="reaction-btn text-lg p-1.5 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors min-h-[40px]" data-post-id="<%= post.id %>" data-emoji="<%= e %>"><%= e %></button>
          <% }) %>
        </div>
      </div>
    </div>
  </article>

  <%# Comments %>
  <section class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 p-5">
    <h2 class="font-semibold text-slate-700 dark:text-slate-200 mb-4"><%= comments.reduce((n, c) => n + 1 + c.replies.length, 0) %> Comments</h2>

    <% if (!comments.length) { %>
    <p class="text-slate-400 dark:text-slate-500 text-sm text-center py-4">No comments yet — say something! 👇</p>
    <% } %>

    <div class="space-y-4 mb-6">
    <% comments.forEach(comment => { %>
      <div class="space-y-3">
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-slate-500 dark:text-slate-300 font-semibold text-xs flex-shrink-0 mt-0.5">
            <%= comment.author_name.charAt(0).toUpperCase() %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="bg-slate-50 dark:bg-slate-700/60 rounded-xl px-3 py-2.5">
              <p class="text-xs font-semibold text-slate-700 dark:text-slate-200 mb-0.5"><%= comment.author_name %></p>
              <p class="text-sm text-slate-700 dark:text-slate-300 whitespace-pre-wrap break-words"><%= comment.content %></p>
            </div>
            <div class="flex items-center gap-3 mt-1.5 px-1 flex-wrap">
              <span class="text-xs text-slate-400 dark:text-slate-500"><%= new Date(comment.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', hour:'numeric', minute:'2-digit' }) %></span>
              <button class="text-xs text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors reply-toggle py-1" data-target="reply-form-<%= comment.id %>">Reply</button>
              <% if (user.id === comment.user_id || user.role === 'admin') { %>
              <form method="POST" action="/comments/<%= comment.id %>/delete" class="inline" onsubmit="return confirm('Delete comment?')">
                <button type="submit" class="text-xs text-slate-400 dark:text-slate-500 hover:text-red-400 transition-colors py-1">Delete</button>
              </form>
              <% } %>
            </div>
            <form method="POST" action="/posts/<%= post.id %>/comments" class="mt-2 hidden" id="reply-form-<%= comment.id %>">
              <input type="hidden" name="parent_id" value="<%= comment.id %>">
              <div class="flex gap-2">
                <input type="text" name="content" placeholder="Write a reply..." required
                  class="flex-1 min-w-0 border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 min-h-[40px]">
                <button type="submit" class="bg-brand-600 text-white text-xs font-medium px-3 py-2 rounded-lg hover:bg-brand-700 transition-colors min-h-[40px] shrink-0">Send</button>
              </div>
            </form>
          </div>
        </div>

        <% comment.replies.forEach(reply => { %>
        <div class="flex gap-3 pl-11">
          <div class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-slate-500 dark:text-slate-300 font-semibold text-xs flex-shrink-0 mt-0.5">
            <%= reply.author_name.charAt(0).toUpperCase() %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="bg-slate-50 dark:bg-slate-700/60 rounded-xl px-3 py-2.5">
              <p class="text-xs font-semibold text-slate-700 dark:text-slate-200 mb-0.5"><%= reply.author_name %></p>
              <p class="text-sm text-slate-700 dark:text-slate-300 whitespace-pre-wrap break-words"><%= reply.content %></p>
            </div>
            <div class="flex items-center gap-3 mt-1.5 px-1 flex-wrap">
              <span class="text-xs text-slate-400 dark:text-slate-500"><%= new Date(reply.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', hour:'numeric', minute:'2-digit' }) %></span>
              <% if (user.id === reply.user_id || user.role === 'admin') { %>
              <form method="POST" action="/comments/<%= reply.id %>/delete" class="inline" onsubmit="return confirm('Delete comment?')">
                <button type="submit" class="text-xs text-slate-400 dark:text-slate-500 hover:text-red-400 transition-colors py-1">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% }) %>
    </div>

    <form method="POST" action="/posts/<%= post.id %>/comments" class="flex gap-2">
      <input type="text" name="content" placeholder="Add a comment..." required
        class="flex-1 min-w-0 border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 min-h-[48px]">
      <button type="submit" class="bg-brand-600 text-white text-sm font-medium px-4 rounded-xl hover:bg-brand-700 transition-colors min-h-[48px] shrink-0">Post</button>
    </form>
  </section>
</div>

<script src="/js/app.js"></script>
<script>
  document.querySelectorAll('.reply-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = document.getElementById(btn.dataset.target);
      form.classList.toggle('hidden');
      if (!form.classList.contains('hidden')) form.querySelector('input[name=content]').focus();
    });
  });

  document.querySelectorAll('.edit-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const postId = btn.dataset.postId;
      const article = document.querySelector(`article[data-post-id="${postId}"]`);
      article.querySelector('.post-content-display').classList.add('hidden');
      article.querySelector('.post-edit-form').classList.remove('hidden');
    });
  });

  document.querySelectorAll('.edit-cancel').forEach(btn => {
    btn.addEventListener('click', () => {
      const postId = btn.dataset.postId;
      const article = document.querySelector(`article[data-post-id="${postId}"]`);
      article.querySelector('.post-content-display').classList.remove('hidden');
      article.querySelector('.post-edit-form').classList.add('hidden');
    });
  });
</script>
</body></html>
