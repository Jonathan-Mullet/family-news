<%- include('partials/head', { title: post.title || 'Post' }) %>
<%- include('partials/nav') %>

<div class="max-w-2xl mx-auto px-4 py-6 space-y-4">
  <a href="/" class="text-sm text-slate-400 hover:text-brand-600 transition-colors">← Back to feed</a>

  <%# Post %>
  <article class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden" data-post-id="<%= post.id %>">
    <div class="p-5">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <div class="w-9 h-9 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 font-semibold flex-shrink-0">
            <%= post.author_name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="font-semibold text-slate-800"><%= post.author_name %></p>
            <p class="text-xs text-slate-400"><%= new Date(post.created_at).toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric', year:'numeric', hour:'numeric', minute:'2-digit' }) %></p>
          </div>
        </div>
        <% if (user.id === post.user_id || user.role === 'admin') { %>
        <form method="POST" action="/posts/<%= post.id %>/delete" onsubmit="return confirm('Delete this post?')">
          <button type="submit" class="text-slate-300 hover:text-red-400 transition-colors">✕</button>
        </form>
        <% } %>
      </div>
      <% if (post.title) { %><h1 class="text-xl font-bold text-slate-800 mb-2"><%= post.title %></h1><% } %>
      <p class="text-slate-700 leading-relaxed whitespace-pre-wrap"><%= post.content %></p>
      <% if (post.photo_url) { %>
      <div class="mt-4 rounded-xl overflow-hidden border border-slate-100">
        <img src="<%= post.photo_url %>" alt="" class="w-full object-cover" onerror="this.parentElement.remove()">
      </div>
      <% } %>
    </div>

    <%# Reactions %>
    <div class="px-5 py-3 border-t border-slate-100 flex items-center gap-1 flex-wrap">
      <% ['❤️','👍','😂','😮','😢'].forEach(emoji => {
        const r = reactions[emoji];
        const count = r?.count || 0;
        const active = r?.userReacted;
      %>
      <button class="reaction-btn flex items-center gap-1 px-2.5 py-1.5 rounded-full text-sm transition-all
        <%= active ? 'bg-brand-50 border border-brand-200' : 'hover:bg-slate-50 border border-transparent' %>"
        data-post-id="<%= post.id %>" data-emoji="<%= emoji %>">
        <span><%= emoji %></span>
        <span class="reaction-count text-xs text-slate-500 <%= count === 0 ? 'hidden' : '' %>"><%= count %></span>
      </button>
      <% }) %>
    </div>
  </article>

  <%# Comments %>
  <section class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5">
    <h2 class="font-semibold text-slate-700 mb-4"><%= comments.reduce((n, c) => n + 1 + c.replies.length, 0) %> Comments</h2>

    <% if (!comments.length) { %>
    <p class="text-slate-400 text-sm text-center py-4">No comments yet — say something! 👇</p>
    <% } %>

    <div class="space-y-4 mb-6">
    <% comments.forEach(comment => { %>
      <div class="space-y-3">
        <%# Top-level comment %>
        <div class="flex gap-3 group">
          <div class="w-7 h-7 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 font-semibold text-xs flex-shrink-0 mt-0.5">
            <%= comment.author_name.charAt(0).toUpperCase() %>
          </div>
          <div class="flex-1">
            <div class="bg-slate-50 rounded-xl px-3 py-2">
              <p class="text-xs font-semibold text-slate-700 mb-0.5"><%= comment.author_name %></p>
              <p class="text-sm text-slate-700 whitespace-pre-wrap"><%= comment.content %></p>
            </div>
            <div class="flex items-center gap-3 mt-1 px-1">
              <span class="text-xs text-slate-400"><%= new Date(comment.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', hour:'numeric', minute:'2-digit' }) %></span>
              <button class="text-xs text-slate-400 hover:text-brand-600 transition-colors reply-toggle" data-target="reply-form-<%= comment.id %>">Reply</button>
              <% if (user.id === comment.user_id || user.role === 'admin') { %>
              <form method="POST" action="/comments/<%= comment.id %>/delete" class="inline">
                <button type="submit" class="text-xs text-slate-300 hover:text-red-400 transition-colors opacity-0 group-hover:opacity-100">Delete</button>
              </form>
              <% } %>
            </div>
            <%# Reply form %>
            <form method="POST" action="/posts/<%= post.id %>/comments" class="mt-2 hidden" id="reply-form-<%= comment.id %>">
              <input type="hidden" name="parent_id" value="<%= comment.id %>">
              <div class="flex gap-2">
                <input type="text" name="content" placeholder="Write a reply..." required
                  class="flex-1 border border-slate-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent">
                <button type="submit" class="bg-brand-600 text-white text-xs font-medium px-3 py-1.5 rounded-lg hover:bg-brand-700 transition-colors">Send</button>
              </div>
            </form>
          </div>
        </div>

        <%# Replies %>
        <% comment.replies.forEach(reply => { %>
        <div class="flex gap-3 pl-10 group">
          <div class="w-7 h-7 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 font-semibold text-xs flex-shrink-0 mt-0.5">
            <%= reply.author_name.charAt(0).toUpperCase() %>
          </div>
          <div class="flex-1">
            <div class="bg-slate-50 rounded-xl px-3 py-2">
              <p class="text-xs font-semibold text-slate-700 mb-0.5"><%= reply.author_name %></p>
              <p class="text-sm text-slate-700 whitespace-pre-wrap"><%= reply.content %></p>
            </div>
            <div class="flex items-center gap-3 mt-1 px-1">
              <span class="text-xs text-slate-400"><%= new Date(reply.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', hour:'numeric', minute:'2-digit' }) %></span>
              <% if (user.id === reply.user_id || user.role === 'admin') { %>
              <form method="POST" action="/comments/<%= reply.id %>/delete" class="inline">
                <button type="submit" class="text-xs text-slate-300 hover:text-red-400 transition-colors opacity-0 group-hover:opacity-100">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% }) %>
    </div>

    <%# New comment form %>
    <form method="POST" action="/posts/<%= post.id %>/comments" class="flex gap-3">
      <div class="w-7 h-7 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 font-semibold text-xs flex-shrink-0 mt-1">
        <%= user.name.charAt(0).toUpperCase() %>
      </div>
      <div class="flex-1 flex gap-2">
        <input type="text" name="content" placeholder="Add a comment..." required
          class="flex-1 border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent">
        <button type="submit" class="bg-brand-600 text-white text-sm font-medium px-4 py-2 rounded-xl hover:bg-brand-700 transition-colors">Post</button>
      </div>
    </form>
  </section>
</div>

<script src="/js/app.js"></script>
<script>
  document.querySelectorAll('.reply-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = document.getElementById(btn.dataset.target);
      form.classList.toggle('hidden');
      if (!form.classList.contains('hidden')) form.querySelector('input[name=content]').focus();
    });
  });
</script>
</body></html>
