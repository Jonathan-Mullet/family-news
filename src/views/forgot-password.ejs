<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="fn-page">
  <div class="fn-page-inner">
    <div class="fn-page-header">
      <h1 class="fn-page-title">Forgot Password</h1>
      <p class="fn-page-sub">We'll send a reset link to your email.</p>
    </div>

    <div class="fn-card">
      <% if (flash.error) { %>
        <div class="fn-flash-error"><%= flash.error %></div>
      <% } %>
      <% if (flash.success) { %>
        <div class="fn-flash-success"><%= flash.success %></div>
      <% } %>

      <form method="POST" action="/forgot-password">
        <div class="fn-field">
          <label class="fn-label" for="fp-email">Email address</label>
          <input class="fn-input" type="email" id="fp-email" name="email" required autocomplete="email" placeholder="your@email.com">
        </div>
        <button type="submit" class="fn-submit">Send Reset Link</button>
      </form>

      <p class="fn-footer-link">Remember it? <a href="/login" class="fn-link">Sign in</a></p>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
</body></html>
