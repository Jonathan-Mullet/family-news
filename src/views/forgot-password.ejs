<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">🔑</div>
      <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100">Forgot password?</h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">We'll send a reset link to your email</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 p-6">
      <% if (flash.error) { %><div class="mb-4 p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg text-red-700 dark:text-red-300 text-sm"><%= flash.error %></div><% } %>
      <% if (flash.success) { %><div class="mb-4 p-3 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-lg text-green-700 dark:text-green-300 text-sm"><%= flash.success %></div><% } %>
      <form method="POST" action="/forgot-password" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-200 mb-1">Email address</label>
          <input type="email" name="email" required autocomplete="email"
            class="w-full border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent min-h-[44px]">
        </div>
        <button type="submit"
          class="w-full bg-brand-600 hover:bg-brand-700 text-white font-medium py-2.5 rounded-lg text-sm transition-colors min-h-[44px]">
          Send reset link
        </button>
      </form>
      <p class="text-center mt-4 text-sm text-slate-400 dark:text-slate-500">
        Remember it? <a href="/login" class="text-brand-600 dark:text-brand-400 hover:underline">Sign in</a>
      </p>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
