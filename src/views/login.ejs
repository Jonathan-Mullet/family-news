<%- include('partials/head') %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">📰</div>
      <h1 class="text-2xl font-bold text-slate-800">Family News</h1>
      <p class="text-slate-500 text-sm mt-1">Sign in to see what's happening</p>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
      <% if (flash.error) { %><div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"><%= flash.error %></div><% } %>
      <% if (flash.success) { %><div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm"><%= flash.success %></div><% } %>
      <form method="POST" action="/login" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" name="email" required autocomplete="email"
            class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
          <input type="password" name="password" required autocomplete="current-password"
            class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent">
        </div>
        <button type="submit"
          class="w-full bg-brand-600 hover:bg-brand-700 text-white font-medium py-2 rounded-lg text-sm transition-colors">
          Sign in
        </button>
      </form>
    </div>
  </div>
</div>
</body></html>
