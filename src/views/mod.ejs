<%- include('partials/head', { title: 'Mod Panel' }) %>
<%- include('partials/nav') %>

<div class="max-w-3xl mx-auto px-4 py-6 space-y-6">
  <h1 class="text-xl font-bold text-slate-800 dark:text-slate-100">Mod Panel</h1>

  <% if (flash.error) { %><div class="p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl text-red-700 dark:text-red-300 text-sm"><%= flash.error %></div><% } %>

  <% if (flash.success && flash.invite_type) { %>
  <div class="p-4 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-xl">
    <p class="text-sm font-semibold text-green-800 dark:text-green-300 mb-2">
      <% if (flash.invite_type === 'open') { %>Open invite — share freely (up to 50 uses, expires in 2 days):<% } else { %>New invite link — share this (single use, expires in 7 days):<% } %>
    </p>
    <div class="flex items-center gap-2 flex-wrap">
      <code class="flex-1 text-xs bg-white dark:bg-slate-800 border border-green-200 dark:border-green-700 rounded-lg px-3 py-2 text-green-700 dark:text-green-300 break-all min-w-0"><%= flash.success %></code>
      <button onclick="navigator.clipboard.writeText(<%- JSON.stringify(flash.success) %>).then(()=>this.textContent='Copied!')"
        class="text-xs bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 transition-colors whitespace-nowrap min-h-[36px] flex-shrink-0">Copy link</button>
    </div>
  </div>
  <% } else if (flash.success) { %>
  <div class="p-3 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-xl text-green-700 dark:text-green-300 text-sm"><%= flash.success %></div>
  <% } %>

  <%# Invites %>
  <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 p-5">
    <div class="flex items-center justify-between mb-4 gap-2 flex-wrap">
      <h2 class="font-semibold text-slate-700 dark:text-slate-200">Invite Links</h2>
      <div class="flex gap-2 flex-wrap">
        <form method="POST" action="/mod/invites">
          <button type="submit" name="type" value="single" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors min-h-[36px]">
            + Single-use (7 days)
          </button>
        </form>
        <form method="POST" action="/mod/invites">
          <button type="submit" name="type" value="open" class="bg-amber-600 hover:bg-amber-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors min-h-[36px]">
            + Open invite (2 days)
          </button>
        </form>
      </div>
    </div>
    <% if (!invites.length) { %>
    <p class="text-slate-400 dark:text-slate-500 text-sm">No active invites.</p>
    <% } else { %>
    <div class="space-y-2">
      <% invites.forEach(invite => { const url = baseUrl + '/register?invite=' + invite.token; %>
      <div class="p-3 bg-slate-50 dark:bg-slate-700/50 rounded-xl">
        <div class="flex items-center gap-3">
          <div class="flex-1 min-w-0">
            <code class="text-xs text-slate-600 dark:text-slate-300 break-all"><%= url %></code>
            <p class="text-xs text-slate-400 dark:text-slate-500 mt-0.5">
              Created by <%= invite.created_by_name %> · Expires <%= new Date(invite.expires_at).toLocaleDateString('en-US', { month:'short', day:'numeric' }) %>
            </p>
          </div>
          <div class="flex gap-2 flex-shrink-0">
            <button onclick="navigator.clipboard.writeText('<%= url %>').then(()=>this.textContent='✓')"
              class="text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 px-2 py-1.5 border border-brand-200 dark:border-brand-700 rounded-lg transition-colors min-h-[32px]">Copy</button>
            <form method="POST" action="/mod/invites/<%= invite.id %>/revoke" onsubmit="return confirm('Revoke this invite?')">
              <button type="submit" class="text-xs text-red-500 hover:text-red-700 px-2 py-1.5 border border-red-200 dark:border-red-800 rounded-lg transition-colors min-h-[32px]">Revoke</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <%# Trash %>
  <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 p-5">
    <h2 class="font-semibold text-slate-700 dark:text-slate-200 mb-1">Trash</h2>
    <p class="text-xs text-slate-400 dark:text-slate-500 mb-4">Deleted items are permanently removed after 14 days.</p>

    <% if (!deletedPosts.length && !standaloneComments.length) { %>
    <p class="text-slate-400 dark:text-slate-500 text-sm text-center py-4">Trash is empty.</p>
    <% } %>

    <%# Deleted posts with their deleted comments %>
    <% if (deletedPosts.length) { %>
    <div class="space-y-4 mb-4">
      <% deletedPosts.forEach(post => { %>
      <div class="border border-slate-200 dark:border-slate-600 rounded-xl overflow-hidden">
        <div class="p-3 bg-slate-50 dark:bg-slate-700/40">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">
                <span class="font-medium text-slate-700 dark:text-slate-200"><%= post.author_name %></span>
                · deleted <time data-ts="<%= new Date(post.deleted_at).toISOString() %>" data-fmt="compact" class="text-slate-400 dark:text-slate-500"></time>
              </p>
              <% if (post.title) { %><p class="text-sm font-semibold text-slate-700 dark:text-slate-200 mb-0.5"><%= post.title %></p><% } %>
              <p class="text-sm text-slate-600 dark:text-slate-300 line-clamp-3 break-words"><%= post.content %></p>
            </div>
            <div class="flex gap-1.5 flex-shrink-0">
              <form method="POST" action="/mod/posts/<%= post.id %>/restore">
                <button type="submit" class="text-xs bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 hover:bg-green-100 dark:hover:bg-green-900/50 px-2.5 py-1.5 border border-green-200 dark:border-green-800 rounded-lg transition-colors min-h-[32px]">Restore</button>
              </form>
              <form method="POST" action="/mod/posts/<%= post.id %>/purge" onsubmit="return confirm('Permanently delete this post and all its content?')">
                <button type="submit" class="text-xs text-red-500 hover:text-red-700 px-2.5 py-1.5 border border-red-200 dark:border-red-800 rounded-lg transition-colors min-h-[32px]">Delete now</button>
              </form>
            </div>
          </div>
        </div>
        <% if (post.deletedComments.length) { %>
        <div class="divide-y divide-slate-100 dark:divide-slate-700">
          <% post.deletedComments.forEach(comment => { %>
          <div class="p-3 flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">
                <span class="font-medium text-slate-600 dark:text-slate-300"><%= comment.author_name %></span>
                · comment deleted <time data-ts="<%= new Date(comment.deleted_at).toISOString() %>" data-fmt="compact" class="text-slate-400 dark:text-slate-500"></time>
              </p>
              <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 break-words"><%= comment.content %></p>
            </div>
            <div class="flex gap-1.5 flex-shrink-0">
              <form method="POST" action="/mod/comments/<%= comment.id %>/restore">
                <button type="submit" class="text-xs bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 hover:bg-green-100 dark:hover:bg-green-900/50 px-2 py-1.5 border border-green-200 dark:border-green-800 rounded-lg transition-colors min-h-[32px]">Restore</button>
              </form>
              <form method="POST" action="/mod/comments/<%= comment.id %>/purge" onsubmit="return confirm('Permanently delete this comment?')">
                <button type="submit" class="text-xs text-red-500 hover:text-red-700 px-2 py-1.5 border border-red-200 dark:border-red-800 rounded-lg transition-colors min-h-[32px]">Delete now</button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
    <% } %>

    <%# Standalone deleted comments (parent post still alive) %>
    <% if (standaloneComments.length) { %>
    <% if (deletedPosts.length) { %>
    <h3 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-2">Deleted comments</h3>
    <% } %>
    <div class="space-y-2">
      <% standaloneComments.forEach(comment => { %>
      <div class="p-3 bg-slate-50 dark:bg-slate-700/40 rounded-xl flex items-start justify-between gap-3">
        <div class="flex-1 min-w-0">
          <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">
            <span class="font-medium text-slate-700 dark:text-slate-200"><%= comment.author_name %></span>
            · on "<%= comment.post_title || comment.post_content.substring(0, 40) %>"
            · deleted <time data-ts="<%= new Date(comment.deleted_at).toISOString() %>" data-fmt="compact" class="text-slate-400 dark:text-slate-500"></time>
          </p>
          <p class="text-sm text-slate-600 dark:text-slate-300 line-clamp-2 break-words"><%= comment.content %></p>
        </div>
        <div class="flex gap-1.5 flex-shrink-0">
          <form method="POST" action="/mod/comments/<%= comment.id %>/restore">
            <button type="submit" class="text-xs bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 hover:bg-green-100 dark:hover:bg-green-900/50 px-2.5 py-1.5 border border-green-200 dark:border-green-800 rounded-lg transition-colors min-h-[32px]">Restore</button>
          </form>
          <form method="POST" action="/mod/comments/<%= comment.id %>/purge" onsubmit="return confirm('Permanently delete this comment?')">
            <button type="submit" class="text-xs text-red-500 hover:text-red-700 px-2.5 py-1.5 border border-red-200 dark:border-red-800 rounded-lg transition-colors min-h-[32px]">Delete now</button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

</div>

<script src="/js/app.js"></script>
</body></html>
