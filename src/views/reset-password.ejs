<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="fn-page">
  <div class="fn-page-inner">
    <div class="fn-page-header">
      <h1 class="fn-page-title">Set New Password</h1>
      <p class="fn-page-sub">Choose something strong.</p>
    </div>

    <div class="fn-card">
      <% if (flash.error) { %>
        <div class="fn-flash-error"><%= flash.error %></div>
      <% } %>

      <form method="POST" action="/reset-password">
        <input type="hidden" name="token" value="<%= token %>">

        <div class="fn-field">
          <label class="fn-label" for="rp-password">New password <span style="font-weight:400;letter-spacing:0;text-transform:none;opacity:0.7;">(min 8 characters)</span></label>
          <input class="fn-input" type="password" id="rp-password" name="password" required minlength="8" autocomplete="new-password">
        </div>

        <button type="submit" class="fn-submit">Reset Password</button>
      </form>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
</body></html>
