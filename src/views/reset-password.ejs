<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">🔒</div>
      <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100">Set new password</h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Choose a strong password</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 p-6">
      <% if (flash.error) { %><div class="mb-4 p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg text-red-700 dark:text-red-300 text-sm"><%= flash.error %></div><% } %>
      <form method="POST" action="/reset-password" class="space-y-4">
        <input type="hidden" name="token" value="<%= token %>">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-200 mb-1">New password <span class="text-slate-400 font-normal">(min 8 characters)</span></label>
          <input type="password" name="password" required minlength="8" autocomplete="new-password"
            class="w-full border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent min-h-[44px]">
        </div>
        <button type="submit"
          class="w-full bg-brand-600 hover:bg-brand-700 text-white font-medium py-2.5 rounded-lg text-sm transition-colors min-h-[44px]">
          Reset password
        </button>
      </form>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
