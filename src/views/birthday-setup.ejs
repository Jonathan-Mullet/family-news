<%- include('partials/head', { title: 'Birthday Setup' }) %>
<%- include('partials/nav') %>

<div class="fn-page">
  <div class="fn-page-inner">
    <div class="fn-page-header">
      <h1 class="fn-page-title">One quick thing</h1>
      <p class="fn-page-sub">When's your birthday? We'll celebrate it with the family. 🎂</p>
    </div>

    <div class="fn-card">
      <% if (flash.error) { %>
        <div class="fn-flash-error"><%= flash.error %></div>
      <% } %>

      <form method="POST" action="/birthday-setup">
        <%
          const _bdMonths = ['January','February','March','April','May','June','July','August','September','October','November','December'];
          const _bdNow = new Date().getFullYear();
        %>
        <div class="fn-field">
          <label class="fn-label">Your birthday</label>
          <div style="display:flex;gap:0.5rem;">
            <select name="birthday_month" class="fn-select" style="flex:1.5;width:auto;min-width:0;" required>
              <option value="" disabled selected>Month</option>
              <% _bdMonths.forEach(function(m, i) { const v = ('0'+(i+1)).slice(-2); %>
              <option value="<%= v %>"><%= m %></option>
              <% }); %>
            </select>
            <select name="birthday_day" class="fn-select" style="flex:0.8;width:auto;min-width:0;" required>
              <option value="" disabled selected>Day</option>
              <% for (let _d = 1; _d <= 31; _d++) { const v = ('0'+_d).slice(-2); %>
              <option value="<%= v %>"><%= _d %></option>
              <% } %>
            </select>
            <select name="birthday_year" class="fn-select" style="flex:1;width:auto;min-width:0;" required>
              <option value="" disabled selected>Year</option>
              <% for (let _y = _bdNow; _y >= 1920; _y--) { %>
              <option value="<%= _y %>"><%= _y %></option>
              <% } %>
            </select>
          </div>
        </div>
        <button type="submit" class="fn-submit">Save and continue</button>
      </form>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
</body></html>
