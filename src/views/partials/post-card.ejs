<article class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden" data-post-id="<%= post.id %>" data-reaction-names="<%= JSON.stringify((reactionNames && reactionNames[post.id]) ? reactionNames[post.id] : {}) %>">
  <% if (post.big_news) { %>
  <div class="px-4 pt-2 pb-0 flex items-center gap-1 text-xs text-amber-700 dark:text-amber-400 font-medium">
    <span>📣</span><span>Big News</span>
  </div>
  <% } else if (post.pinned) { %>
  <div class="px-4 pt-2 pb-0 flex items-center gap-1 text-xs text-brand-600 dark:text-brand-400 font-medium">
    <span>📌</span><span>Pinned</span>
  </div>
  <% } %>
  <div class="p-4">
    <%# Header %>
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <a href="/member/<%= post.user_id %>" class="flex-shrink-0">
        <% if (post.author_avatar) { %>
        <img src="<%= post.author_avatar %>" class="w-9 h-9 rounded-full object-cover" alt="">
        <% } else { %>
        <div class="w-9 h-9 rounded-full bg-brand-100 dark:bg-brand-600/20 flex items-center justify-center text-brand-600 dark:text-brand-400 font-semibold text-sm">
          <%= post.author_name.charAt(0).toUpperCase() %>
        </div>
        <% } %>
        </a>
        <div>
          <a href="/member/<%= post.user_id %>" class="text-sm font-semibold text-slate-800 dark:text-slate-100 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"><%= post.author_name %></a>
          <p class="text-xs text-slate-400 dark:text-slate-500 flex items-center gap-1.5">
            <% if (isScheduled && (user.id === post.user_id || user.role === 'admin')) { %>
            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-amber-50 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 rounded font-medium">🕐 Scheduled</span>
            <% } else { %>
            <time data-ts="<%= new Date(post.created_at).toISOString() %>"></time>
            <% if (post.edited_at) { %><span class="italic"> · edited</span><% } %>
            <% } %>
          </p>
        </div>
      </div>
      <% if (user.id === post.user_id || user.role === 'admin') { %>
      <div class="flex items-center gap-1">
        <% if (user.role === 'admin') { %>
        <form method="POST" action="/posts/<%= post.id %>/pin">
          <button type="submit" class="min-h-[44px] min-w-[44px] flex items-center justify-center text-slate-300 dark:text-slate-600 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" title="<%= post.pinned ? 'Unpin post' : 'Pin post' %>">
            <span class="text-sm"><%= post.pinned ? '📌' : '📍' %></span>
          </button>
        </form>
        <% } %>
        <form method="POST" action="/posts/<%= post.id %>/toggle-big-news">
          <button type="submit" class="min-h-[44px] min-w-[44px] flex items-center justify-center transition-colors <%= post.big_news ? 'text-amber-500 dark:text-amber-400 hover:text-amber-700' : 'text-slate-300 dark:text-slate-600 hover:text-amber-500 dark:hover:text-amber-400' %>" title="<%= post.big_news ? 'Unmark Big News' : 'Mark as Big News' %>">
            <span class="text-sm">📣</span>
          </button>
        </form>
        <button class="edit-toggle min-h-[44px] min-w-[44px] flex items-center justify-center text-slate-300 dark:text-slate-600 hover:text-brand-600 dark:hover:text-brand-400 transition-colors text-xs" data-post-id="<%= post.id %>" title="Edit post">✏️</button>
        <form method="POST" action="/posts/<%= post.id %>/delete" onsubmit="return confirm('Delete this post?')">
          <button type="submit" class="min-h-[44px] min-w-[44px] flex items-center justify-center text-slate-300 dark:text-slate-600 hover:text-red-400 transition-colors text-sm">✕</button>
        </form>
      </div>
      <% } %>
    </div>

    <%# Content display %>
    <div class="post-content-display">
      <% if (post.title) { %><h2 class="font-semibold text-slate-800 dark:text-slate-100 mb-1"><%= post.title %></h2><% } %>
      <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed whitespace-pre-wrap"><%= post.content %></p>
    </div>

    <%# Inline edit form %>
    <form method="POST" action="/posts/<%= post.id %>/edit" class="post-edit-form hidden space-y-2">
      <input type="text" name="title" placeholder="Title (optional)" value="<%= post.title || '' %>"
        class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-600">
      <textarea name="content" rows="4" required maxlength="2000"
        class="w-full border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 rounded-xl px-3 py-2 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-brand-600"><%= post.content %></textarea>
      <div class="flex gap-2 justify-end">
        <button type="button" class="edit-cancel text-xs text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 px-3 py-1.5 border border-slate-200 dark:border-slate-600 rounded-lg transition-colors" data-post-id="<%= post.id %>">Cancel</button>
        <button type="submit" class="text-xs bg-brand-600 hover:bg-brand-700 text-white px-3 py-1.5 rounded-lg transition-colors font-medium">Save</button>
      </div>
    </form>

    <%# Photos %>
    <% if (post.photos && post.photos.length) { %>
    <div class="mt-3">
      <% if (post.photos.length === 1) { %>
      <div class="rounded-xl overflow-hidden border border-slate-100 dark:border-slate-700">
        <img src="<%= post.photos[0] %>" alt="" class="w-full object-cover max-h-80" loading="lazy" onerror="this.parentElement.remove()">
      </div>
      <% } else { %>
      <div class="flex gap-2 overflow-x-auto pb-1">
        <% post.photos.forEach(url => { %>
        <div class="shrink-0 w-44 h-44 rounded-xl overflow-hidden border border-slate-100 dark:border-slate-700">
          <img src="<%= url %>" alt="" class="w-full h-full object-cover" loading="lazy" onerror="this.parentElement.remove()">
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
    <% } %>

    <%# Link preview %>
    <% if (post.preview_url && (!post.photos || !post.photos.length)) { %>
    <a href="<%= post.preview_url %>" target="_blank" rel="noopener" class="mt-3 flex gap-3 border border-slate-200 dark:border-slate-600 rounded-xl p-3 hover:border-brand-400 dark:hover:border-brand-500 transition-colors overflow-hidden">
      <% if (post.og_image) { %><img src="<%= post.og_image %>" class="w-16 h-16 object-cover rounded-lg flex-shrink-0" loading="lazy" onerror="this.remove()"><% } %>
      <div class="min-w-0">
        <p class="text-sm font-medium text-slate-700 dark:text-slate-200 truncate"><%= post.og_title || post.preview_url %></p>
        <% if (post.og_description) { %><p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 mt-0.5"><%= post.og_description %></p><% } %>
      </div>
    </a>
    <% } %>
  </div>

  <%# Reactions — Teams-like chip+picker %>
  <%
    const _emojiOrder = ['❤️','👍','😂','😮','😢','🎉','🙏','🔥','💯','🫶','👏','🥳','😍','🤣','😭','💪','🎂','🌟','👀','🤔','💔'];
    const _reactData = {};
    _emojiOrder.forEach(e => {
      const r = reactionsByPost?.[post.id]?.[e];
      if (r?.count) _reactData[e] = { count: r.count, userReacted: !!r.userReacted };
    });
    const _rn = (reactionNames && reactionNames[post.id]) ? reactionNames[post.id] : {};
    const _summaryParts = _emojiOrder
      .filter(e => _rn[e]?.length > 0)
      .map(e => {
        const ns = _rn[e];
        if (ns.length <= 2) return e + ' ' + ns.join(', ');
        return e + ' ' + ns.slice(0, 2).join(', ') + ' +' + (ns.length - 2);
      });
  %>
  <div class="px-4 py-2 border-t border-slate-100 dark:border-slate-700">
    <div class="flex items-center gap-1.5 flex-wrap" id="reaction-chips-<%= post.id %>" data-reactions="<%= JSON.stringify(_reactData) %>">

      <%# Chips for all currently-reacted emojis %>
      <% _emojiOrder.forEach(emoji => {
        if (!_reactData[emoji]) return;
        const r = _reactData[emoji];
      %>
      <button class="reaction-chip reaction-btn flex items-center gap-1 px-2 py-1 rounded-full text-sm border transition-all min-h-[30px]
        <%= r.userReacted ? 'bg-brand-50 dark:bg-brand-600/20 border-brand-300 dark:border-brand-600' : 'bg-slate-50 dark:bg-slate-700/40 border-slate-200 dark:border-slate-600 hover:border-brand-300 dark:hover:border-brand-500' %>"
        data-post-id="<%= post.id %>" data-emoji="<%= emoji %>">
        <span><%= emoji %></span>
        <span class="reaction-count text-xs font-medium text-slate-500 dark:text-slate-400"><%= r.count %></span>
      </button>
      <% }) %>

      <%# React button + floating picker %>
      <div class="relative">
        <button class="emoji-picker-toggle flex items-center gap-1 text-xs text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors px-2 py-1 rounded-full border border-transparent hover:border-slate-200 dark:hover:border-slate-600 min-h-[30px]" data-post-id="<%= post.id %>">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.536-4.464a.75.75 0 10-1.061-1.061 3.5 3.5 0 01-4.95 0 .75.75 0 00-1.06 1.06 5 5 0 007.07 0zM9 8.5c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S7.448 7 8 7s1 .672 1 1.5zm3 1.5c.552 0 1-.672 1-1.5S12.552 7 12 7s-1 .672-1 1.5.448 1.5 1 1.5z" clip-rule="evenodd" />
          </svg>
          React
        </button>
        <div class="emoji-picker hidden absolute bottom-full mb-1 left-0 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 rounded-2xl shadow-xl p-2 z-20">
          <div class="grid grid-cols-7 gap-0.5">
            <% _emojiOrder.forEach(e => {
              const active = !!_reactData[e]?.userReacted;
            %>
            <button class="reaction-btn text-xl p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors min-h-[38px] min-w-[38px] flex items-center justify-center<%= active ? ' bg-brand-50 dark:bg-brand-600/20' : '' %>"
              data-post-id="<%= post.id %>" data-emoji="<%= e %>"><%= e %></button>
            <% }) %>
          </div>
        </div>
      </div>

    </div>

    <%# Names summary — tap to see who reacted %>
    <% if (_summaryParts.length) { %>
    <button class="reaction-summary text-xs text-slate-400 dark:text-slate-500 mt-1 py-1 leading-relaxed text-left w-full hover:text-slate-600 dark:hover:text-slate-300 transition-colors"><%= _summaryParts.join(' · ') %></button>
    <% } %>
  </div>

  <%# Latest comment preview %>
  <% const _lc = latestCommentByPost && latestCommentByPost[post.id]; %>
  <% if (_lc) { %>
  <div class="px-4 py-2.5 border-t border-slate-100 dark:border-slate-700 flex gap-2 items-start">
    <% if (_lc.author_avatar) { %>
    <img src="<%= _lc.author_avatar %>" class="w-6 h-6 rounded-full object-cover flex-shrink-0 mt-0.5" alt="">
    <% } else { %>
    <div class="w-6 h-6 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-slate-500 dark:text-slate-300 font-semibold text-xs flex-shrink-0 mt-0.5">
      <%= _lc.author_name.charAt(0).toUpperCase() %>
    </div>
    <% } %>
    <div class="min-w-0 flex-1">
      <a href="/member/<%= _lc.author_id %>" class="text-xs font-semibold text-slate-700 dark:text-slate-200 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"><%= _lc.author_name %></a>
      <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 break-words"><%= _lc.content %></p>
    </div>
  </div>
  <% } %>

  <%# Inline comment form %>
  <div class="px-4 py-2.5 border-t border-slate-100 dark:border-slate-700">
    <form method="POST" action="/posts/<%= post.id %>/comments" class="flex gap-2">
      <input type="text" name="content" placeholder="Add a comment..." required
        class="flex-1 min-w-0 border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-brand-600 min-h-[36px]">
      <button type="submit" class="bg-brand-600 text-white text-xs font-medium px-3 rounded-lg hover:bg-brand-700 transition-colors min-h-[36px] shrink-0">Send</button>
    </form>
  </div>
</article>
